{
  "name": "firstresponders",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=packages/backend",
    "dev:web": "npm run dev --workspace=packages/web",
    "build:shared": "npm run build --workspace=packages/shared",
    "db:migrate": "npm run db:migrate --workspace=packages/backend",
    "db:seed": "npm run db:seed --workspace=packages/backend",
    "db:generate": "npm run db:generate --workspace=packages/backend"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.0"
  },
  "dependencies": {
    "expo-crypto": "^55.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native-get-random-values": "^2.0.0"
  }
}
