{
  "expo": {
    "name": "FirstResponders",
    "slug": "firstresponders",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "firstresponders",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#dc2626"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.firstresponders.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is used to capture incident scene photos.",
        "NSLocationWhenInUseUsageDescription": "Location is used to geotag incident photos and auto-fill incident location.",
        "NSPhotoLibraryUsageDescription": "Photo library access allows you to attach existing photos to incidents."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#dc2626"
      },
      "package": "com.firstresponders.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "platforms": ["ios", "android"],
    "updates": {
      "url": "https://u.expo.dev/9b81636d-15bd-469e-9eef-cd269fbd40e0",
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "channel": "production"
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow FirstResponders to access your camera."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow FirstResponders to access your location."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow FirstResponders to access your photos."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9b81636d-15bd-469e-9eef-cd269fbd40e0"
      }
    },
    "owner": "fr-expogo"
  }
}
